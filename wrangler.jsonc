{
  "name": "vtracker",
  "compatibility_date": "2026-03-21",
  "main": "worker.js",
  "assets": {
    "directory": "./deploy-assets",
    "binding": "ASSETS"
  },
  "triggers": {
    "crons": [
      "*/1 * * * *"
    ]
  },
  "vars": {
    "ENABLE_WORKER_INGEST": "false",
    "ENABLE_SUPABASE_READS": "true",
    "VATSIM_URL": "https://data.vatsim.net/v3/vatsim-data.json",
    "SUPABASE_URL": "https://rjqktrzprvvcacfdejoe.supabase.co"
  }
}
